SPRING_PROFILE=dev

JAVA_OPTS=-Xms256m -Xmx512m

ZOOKEEPER_VERSION=7.5.0
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

KAFKA_VERSION=7.5.0
KAFKA_PORT=9092
KAFKA_BROKER_ID=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

API_GATEWAY_PORT=8080

AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
WALLET_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
LEDGER_SERVICE_PORT=8085
FRAUD_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087

FRONTEND_PORT=3000

AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8082
WALLET_SERVICE_URL=http://wallet-service:8083
PAYMENT_SERVICE_URL=http://payment-service:8084
LEDGER_SERVICE_URL=http://ledger-service:8085
FRAUD_SERVICE_URL=http://fraud-service:8086

JWT_SECRET=your_secure_jwt_secret_here
JWT_EXPIRATION=86400000

POSTGRES_URL=your_postgresql_connection_url
POSTGRES_USERNAME=your_postgresql_username
POSTGRES_PASSWORD=your_postgresql_password
POSTGRES_DRIVER=org.postgresql.Driver

HIBERNATE_DDL_AUTO=update
HIBERNATE_SHOW_SQL=false
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://your_server_ip:3000

SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000
SPRING_JPA_OPEN_IN_VIEW=false