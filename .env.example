SPRING_PROFILE=dev

# =========================================================
# JVM OPTIMIZATION
# =========================================================

JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# =========================================================
# ZOOKEEPER
# =========================================================

ZOOKEEPER_VERSION=7.5.0
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# =========================================================
# KAFKA
# =========================================================

KAFKA_VERSION=7.5.0
KAFKA_PORT=9092
KAFKA_BROKER_ID=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# =========================================================
# SERVICE PORTS
# =========================================================

API_GATEWAY_PORT=8080

AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
WALLET_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
LEDGER_SERVICE_PORT=8085
FRAUD_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087

FRONTEND_PORT=3000

# =========================================================
# INTERNAL SERVICE URLS
# =========================================================

AUTH_SERVICE_URL=http://auth-service:8081

USER_SERVICE_URL=http://user-service:8082

WALLET_SERVICE_URL=http://wallet-service:8083

PAYMENT_SERVICE_URL=http://payment-service:8084

LEDGER_SERVICE_URL=http://ledger-service:8085

FRAUD_SERVICE_URL=http://fraud-service:8086

# =========================================================
# JWT
# =========================================================

JWT_SECRET=your_jwt_secret_here

JWT_EXPIRATION=86400000

# =========================================================
# POSTGRESQL
# =========================================================

POSTGRES_DB=fintech

POSTGRES_USER=postgres

POSTGRES_PASSWORD=your_postgres_password_here

POSTGRES_PORT=5432

POSTGRES_DRIVER=org.postgresql.Driver

SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# =========================================================
# DATABASE URLS
# =========================================================

AUTH_DB_URL=jdbc:postgresql://postgres:5432/auth_db

USER_DB_URL=jdbc:postgresql://postgres:5432/user_db

WALLET_DB_URL=jdbc:postgresql://postgres:5432/wallet_db

PAYMENT_DB_URL=jdbc:postgresql://postgres:5432/payment_db

LEDGER_DB_URL=jdbc:postgresql://postgres:5432/ledger_db

FRAUD_DB_URL=jdbc:postgresql://postgres:5432/fraud_db

# =========================================================
# HIBERNATE / JPA
# =========================================================

HIBERNATE_DDL_AUTO=update

HIBERNATE_SHOW_SQL=false

HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

SPRING_JPA_HIBERNATE_DDL_AUTO=update

SPRING_JPA_SHOW_SQL=false

SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

SPRING_JPA_OPEN_IN_VIEW=false

# =========================================================
# HIKARI CONNECTION POOL
# =========================================================

SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10

SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2

SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000

SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000

SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# =========================================================
# CORS
# =========================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://your-server-ip:3000
